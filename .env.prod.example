# Copy to .env.prod and fill real values.

# App
APP_ENV=prod
APP_DEBUG=false
APP_SECRET_KEY=change-me-generate-with-secrets-token-urlsafe-32

# Database (service-name hosts — inside the compose network)
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_DB=gateway
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gateway:gateway@postgres:5432/gateway

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ / Celery
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# LLM Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ENABLE_ANTHROPIC=false

# Cache
CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.90
EMBEDDING_MODEL=models/gemini-embedding-001

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_DAY=10000

# Fallback
PROVIDER_FALLBACK_ORDER=gemini,openai
PROVIDER_RETRY_ATTEMPTS=2
PROVIDER_RETRY_DELAY_SECONDS=1

# Runtime knobs (read by entrypoint)
WEB_CONCURRENCY=2
CELERY_CONCURRENCY=2
CELERY_LOG_LEVEL=info
