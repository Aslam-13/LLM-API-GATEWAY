{
  "name": "llm-gateway",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" },
    "ghcr.io/devcontainers/features/node:1":   { "version": "22" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [80, 8000, 5173, 15672],
  "portsAttributes": {
    "80":    { "label": "Dashboard + API (public)",  "visibility": "public" },
    "8000":  { "label": "FastAPI (direct)",          "visibility": "private" },
    "5173":  { "label": "Vite dev server",           "visibility": "private" },
    "15672": { "label": "RabbitMQ management UI",    "visibility": "private" }
  },
  "postCreateCommand": "python3.11 -m venv .venv && .venv/bin/pip install -U pip && .venv/bin/pip install -r requirements-dev.txt && (cd dashboard && npm ci)",
  "remoteUser": "vscode"
}
